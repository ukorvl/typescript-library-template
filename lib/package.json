{
  "name": "typescript-library-template",
  "version": "0.0.1",
  "description": "Template TypeScript library package",
  "keywords": [],
  "homepage": "https://github.com/your-org/typescript-library-template",
  "bugs": {
    "url": "https://github.com/your-org/typescript-library-template/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/typescript-library-template.git",
    "directory": "lib"
  },
  "license": "MIT",
  "author": "Template Maintainers <maintainers@example.com>",
  "sideEffects": false,
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/typescript-library-template.mjs",
      "default": "./dist/typescript-library-template.mjs"
    }
  },
  "main": "dist/typescript-library-template.mjs",
  "unpkg": "dist/typescript-library-template.umd.js",
  "module": "dist/typescript-library-template.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "lint:exports": "npm_config_cache=.npm-cache attw --pack . --ignore-rules=cjs-resolves-to-esm",
    "test": "vitest run --config vitest.config.ts --coverage",
    "typecheck": "tsc --noEmit --project tsconfig.json"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "vite-plugin-dts": "^4.5.4"
  },
  "peerDependenciesMeta": {},
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  }
}
