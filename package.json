{
  "name": "fill-me-monorepo",
  "version": "0.0.1",
  "private": true,
  "description": "fill-me",
  "license": "MIT",
  "author": "fill-me <fill-me@fill-me.com>",
  "directories": {
    "lib": "lib",
    "doc": "docs",
    "example": "example"
  },
  "scripts": {
    "build": "echo \"no build specified\" && exit 0",
    "dev": "concurrently \"pnpm -C lib dev\" \"pnpm -C docs dev\" \"pnpm -C example dev\" --kill-others --success last",
    "format": "prettier --check \"**/*.{js,ts,jsx,tsx,json,md,yaml,yml}\"",
    "format:fix": "prettier --write \"**/*.{js,ts,jsx,tsx,json,md,yaml,yml}\"",
    "install-git-hooks": "pnpm exec simple-git-hooks",
    "knip": "knip --cache --production",
    "lint": "eslint --cache --ext .ts,.tsx,.js,.jsx,.mjs,.cjs .",
    "lint:commits": "bash -c \"if git rev-parse --verify HEAD~1 >/dev/null 2>&1; then pnpm exec commitlint --from=HEAD~1 --to=HEAD; else pnpm exec commitlint --last; fi\"",
    "lint:fix": "eslint --cache --fix --ext .ts,.tsx,.js,.jsx,.mjs,.cjs .",
    "prepare": "pnpm run install-git-hooks",
    "test": "echo \"no test specified\" && exit 0",
    "version": "bash ./scripts/version.sh"
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm exec commitlint --edit $1",
    "preserveUnused": [
      "commit-msg"
    ]
  },
  "overrides": {
    "eslint": "^9.30.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@commitlint/format": "^20.0.0",
    "@eslint/js": "^9.39.4",
    "@size-limit/preset-small-lib": "^12.0.0",
    "@types/node": "^24.6.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.30.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.7.1",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-perfectionist": "^5.7.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-vitest": "^0.5.4",
    "globals": "^17.3.0",
    "knip": "^5.64.1",
    "prettier": "^3.7.3",
    "prettier-plugin-multiline-arrays": "^4.1.3",
    "prettier-plugin-packagejson": "^3.0.0",
    "prettier-plugin-sort-json": "^4.2.0",
    "simple-git-hooks": "^2.13.1",
    "size-limit": "^12.0.0",
    "typescript": "^5",
    "typescript-eslint": "^8.53.1",
    "vite": "^7.1.9",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.17"
  },
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=10.11.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "oxc-resolver",
      "simple-git-hooks",
      "unrs-resolver"
    ]
  },
  "knip": {
    "ignoreBinaries": [
      "commitlint",
      "commit-msg"
    ]
  }
}
